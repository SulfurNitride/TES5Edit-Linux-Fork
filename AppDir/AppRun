#!/bin/bash
# =============================================================================
# AppRun - Entry point for the xEdit AppImage
# =============================================================================
APPDIR="$(dirname "$(readlink -f "$0")")"

# Bundled shared libraries
export LD_LIBRARY_PATH="${APPDIR}/usr/lib:${LD_LIBRARY_PATH:-}"

# Qt6 plugins — must set both so Qt finds platform plugins
export QT_PLUGIN_PATH="${APPDIR}/usr/plugins"
export QT_QPA_PLATFORM_PLUGIN_PATH="${APPDIR}/usr/plugins/platforms"

# Suppress harmless Qt6/Wayland noise
export QT_LOGGING_RULES="qt.qpa.wayland.warning=false;qt.core.qobject.connect=false"

# XDG data dirs for desktop integration
export XDG_DATA_DIRS="${APPDIR}/usr/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"

exec "${APPDIR}/usr/bin/xEditLaz" "$@"
