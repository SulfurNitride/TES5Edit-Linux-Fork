+// Helper: ensure a widget's popup window has its transient parent set for Wayland.
+static void ensureComboTransientParent(QComboBox *combo)
+{
+	if (!combo)
+		return;
+	// The popup view is the dropdown list
+	QAbstractItemView *view = combo->view();
+	if (!view)
+		return;
+	QWidget *popup = view->window();
+	if (!popup)
+		return;
+	QWindow *popupWindow = popup->windowHandle();
+	if (!popupWindow)
+		return;
+	if (popupWindow->transientParent())
+		return;
+	QWindow *parentWindow = combo->windowHandle();
+	if (!parentWindow)
+		parentWindow = combo->window() ? combo->window()->windowHandle() : nullptr;
+	if (parentWindow)
+		popupWindow->setTransientParent(parentWindow);
+}
