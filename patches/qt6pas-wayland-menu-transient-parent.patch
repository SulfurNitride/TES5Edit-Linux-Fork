+// Helper: ensure a widget's window has its transient parent set.
+// On Wayland, popups require a transient parent to be properly positioned.
+static void ensureTransientParent(QWidget *popup)
+{
+	if (!popup)
+		return;
+	QWindow *popupWindow = popup->windowHandle();
+	if (!popupWindow)
+		return;
+	if (popupWindow->transientParent())
+		return; // already set
+
+	// Walk up the widget parent chain to find a suitable parent window
+	QWidget *parent = popup->parentWidget();
+	if (!parent)
+		parent = QApplication::activeWindow();
+	if (parent) {
+		QWindow *parentWindow = parent->windowHandle();
+		if (parentWindow)
+			popupWindow->setTransientParent(parentWindow);
+	}
+}
+
 void QMenu_popup(QMenuH handle, const QPointH pos, QActionH at)
 {
-	((QMenu *)handle)->popup(*(const QPoint*)pos, (QAction*)at);
+	QMenu *menu = (QMenu *)handle;
+	// Ensure the menu window has a transient parent for Wayland
+	menu->winId(); // force window handle creation
+	ensureTransientParent(menu);
+	menu->popup(*(const QPoint*)pos, (QAction*)at);
 }

 QActionH QMenu_exec(QMenuH handle)
 {
-	return (QActionH) ((QMenu *)handle)->exec();
+	QMenu *menu = (QMenu *)handle;
+	menu->winId();
+	ensureTransientParent(menu);
+	return (QActionH) menu->exec();
 }

